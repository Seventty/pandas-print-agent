<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Pandas.PrintAgent.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="760"
        d:DesignHeight="780"
        x:Class="Pandas.PrintAgent.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/pandas-logo.ico"
        Title="PANDAS Print Agent"
        Width="760"
        Height="780"
        MinWidth="760"
        MinHeight="560"
        MaxWidth="760"
        MaxHeight="780"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="False"
        Background="#F6F8FA">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#27384A"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Foreground" Value="#15202B"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#B9C4D0"/>
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="Foreground" Value="#15202B"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#B9C4D0"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Foreground" Value="#15202B"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#B9C4D0"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#27384A"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Foreground" Value="#15202B"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#B9C4D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#EEF3F7"/>
            <Setter Property="BorderBrush" Value="#8DA2B5"/>
        </Style>
        <Style Selector="Button.text-link">
            <Setter Property="Foreground" Value="#2F5F8F"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.text-link:pointerover">
            <Setter Property="Foreground" Value="#173F69"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.contact-button">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>
    </Window.Styles>

    <Grid>
        <ScrollViewer>
        <Grid Margin="24" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="18">
            <Border Grid.Row="0"
                    Padding="18"
                    CornerRadius="6"
                    Background="#FFFFFF"
                    BorderBrush="#D9E0E7"
                    BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="6" ColumnSpacing="16">
                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="0">
                        <TextBlock Text="PANDAS"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="#15202B"/>
                        <TextBlock Text="Print Agent"
                                   FontSize="14"
                                   Foreground="#536170"/>
                    </StackPanel>
                    <Button Grid.Row="0"
                            Grid.Column="1"
                            Content="Actualizar"
                            Command="{Binding RestartForUpdateCommand}"
                            IsVisible="{Binding IsUpdateReady}"
                            MinWidth="104"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               Text="{Binding StatusText}"
                               TextWrapping="Wrap"
                               Foreground="{Binding StatusForeground}"
                               FontWeight="SemiBold"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12" ColumnSpacing="12">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Backend URL" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BackendBaseUrl}" PlaceholderText="https://backend.example.com"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="API prefix" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ApiPrefix}" PlaceholderText="api"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Token (opcional)" VerticalAlignment="Center"/>
                <Grid Grid.Row="2" Grid.Column="1" ColumnDefinitions="*,42">
                    <TextBox Grid.Column="0"
                             Grid.ColumnSpan="2"
                             Text="{Binding AgentToken}"
                             PasswordChar="{Binding TokenPasswordChar}"
                             PlaceholderText="Dejar vacio si el backend no exige token"
                             Padding="10,6,44,6"/>
                    <Button Grid.Column="1"
                            Command="{Binding ToggleTokenVisibilityCommand}"
                            ToolTip.Tip="{Binding TokenVisibilityLabel}"
                            Width="34"
                            Height="28"
                            Margin="0,2,4,2"
                            Padding="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0">
                        <Viewbox Width="18" Height="18">
                            <Grid Width="24" Height="24">
                                <Path Data="M12 5 C7 5 3 12 3 12 C3 12 7 19 12 19 C17 19 21 12 21 12 C21 12 17 5 12 5 Z"
                                      Stroke="#3D4B5C"
                                      StrokeThickness="2"
                                      Fill="Transparent"/>
                                <Ellipse Width="6"
                                         Height="6"
                                         Stroke="#3D4B5C"
                                         StrokeThickness="2"
                                         Fill="Transparent"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                                <Path Data="M4 4 L20 20"
                                      IsVisible="{Binding IsTokenVisible}"
                                      Stroke="#3D4B5C"
                                      StrokeThickness="2"/>
                            </Grid>
                        </Viewbox>
                    </Button>
                </Grid>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Conector" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="3"
                          Grid.Column="1"
                          ItemsSource="{Binding ConnectorOptions}"
                          SelectedItem="{Binding SelectedConnectorOption}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:PrinterConnectorOption">
                            <TextBlock Text="{Binding Label}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="12" ColumnSpacing="12">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Printer host" VerticalAlignment="Center" IsVisible="{Binding IsNetworkConnector}"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PrinterHost}" PlaceholderText="10.0.0.28" IsVisible="{Binding IsNetworkConnector}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Printer port" VerticalAlignment="Center" IsVisible="{Binding IsNetworkConnector}"/>
                <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding PrinterPort}" Minimum="1" Maximum="65535" Increment="1" IsVisible="{Binding IsNetworkConnector}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding PrinterQueueLabel}" VerticalAlignment="Center" IsVisible="{Binding IsInstalledPrinterConnector}"/>
                <Grid Grid.Row="2" Grid.Column="1" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4" ColumnSpacing="8" IsVisible="{Binding IsInstalledPrinterConnector}">
                    <ComboBox Grid.Row="0"
                              Grid.Column="0"
                              ItemsSource="{Binding InstalledPrinterOptions}"
                              SelectedItem="{Binding SelectedInstalledPrinterOption}"
                              PlaceholderText="Selecciona una impresora instalada">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:InstalledPrinterOption">
                                <TextBlock Text="{Binding Label}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Row="0"
                            Grid.Column="1"
                            Content="Refrescar"
                            Command="{Binding RefreshInstalledPrintersCommand}"
                            MinWidth="92"/>
                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               Text="{Binding InstalledPrinterListStatusText}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#536170"/>
                </Grid>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Estado impresora" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PrinterStatusText}" TextWrapping="Wrap" Foreground="{Binding PrinterStatusForeground}" FontWeight="SemiBold"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Poll interval ms" VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="4" Grid.Column="1" Value="{Binding PollIntervalMs}" Minimum="250" Maximum="60000" Increment="250"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Printer timeout ms" VerticalAlignment="Center"/>
                <NumericUpDown Grid.Row="5" Grid.Column="1" Value="{Binding PrinterTimeoutMs}" Minimum="500" Maximum="60000" Increment="500"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Job target" VerticalAlignment="Center" IsVisible="{Binding IsNetworkConnector}"/>
                <CheckBox Grid.Row="6" Grid.Column="1" IsChecked="{Binding UseJobPrinterTarget}" Content="Usar targetHost/targetPort del trabajo cuando venga definido" IsVisible="{Binding IsNetworkConnector}"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Payload dumps" VerticalAlignment="Center"/>
                <CheckBox Grid.Row="7" Grid.Column="1" IsChecked="{Binding SavePayloads}" Content="Guardar payload binario de cada trabajo"/>
            </Grid>

            <Grid Grid.Row="3" ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="12" ColumnSpacing="12">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Log file" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding LogFilePath}" PlaceholderText="logs/print-agent.log"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Payload folder" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PayloadDumpDirectory}" PlaceholderText="logs/payloads"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Ultimo trabajo" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastJob}" TextWrapping="Wrap" Foreground="#27384A"/>
            </Grid>

            <Grid Grid.Row="4" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                <WrapPanel Grid.Row="0" HorizontalAlignment="Right" ItemSpacing="8">
                    <Button Content="Guardar" Command="{Binding SaveCommand}" MinWidth="96"/>
                    <Button Content="Reload" Command="{Binding ReloadCommand}" MinWidth="96"/>
                    <Button Content="Status" Command="{Binding CheckBackendCommand}" MinWidth="96"/>
                    <Button Content="{Binding TestPrinterButtonText}" Command="{Binding TestPrinterCommand}" MinWidth="148"/>
                    <Button Content="Abrir logs" Command="{Binding OpenLogsCommand}" MinWidth="104"/>
                    <Button Content="Salir" Command="{Binding ExitCommand}" MinWidth="84"/>
                </WrapPanel>

                <Border Grid.Row="1"
                        Padding="12"
                        Background="#EEF3F7"
                        BorderBrush="#D9E0E7"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TextBlock Text="{Binding LastLogLine}" TextWrapping="Wrap" Foreground="#27384A"/>
                </Border>

                <Border Grid.Row="2"
                        Height="1"
                        Margin="0,4,0,0"
                        Background="#D9E0E7"/>

                <Grid Grid.Row="3" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" Margin="0,2,0,0">
                    <TextBlock Grid.Column="0"
                               Grid.Row="0"
                               Text="{Binding CopyrightText}"
                               FontSize="12"
                               Foreground="#536170"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="0"
                               Grid.Row="1"
                               Text="{Binding AppVersionText}"
                               FontSize="12"
                               Foreground="#536170"
                               Margin="0,2,0,0"/>
                    <Button Grid.Column="1"
                            Grid.Row="0"
                            Grid.RowSpan="2"
                            Classes="text-link"
                            Content="contacto"
                            Command="{Binding OpenContactCommand}"
                            FontSize="12"
                            VerticalAlignment="Center"/>
                </Grid>
            </Grid>
        </Grid>
        </ScrollViewer>

        <Border Background="#66000000"
                IsVisible="{Binding IsContactModalOpen}">
            <Border Width="360"
                    Padding="18"
                    CornerRadius="6"
                    Background="#FFFFFF"
                    BorderBrush="#D9E0E7"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="16">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Contacto"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#15202B"/>
                            <TextBlock Text="Rainiery Valerio Gonzalez"
                                       FontSize="13"
                                       Foreground="#536170"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding CloseContactCommand}"
                                ToolTip.Tip="Cerrar"
                                Width="32"
                                Height="32"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                VerticalAlignment="Top">
                            <Viewbox Width="14" Height="14">
                                <Path Width="24"
                                      Height="24"
                                      Stroke="#536170"
                                      StrokeThickness="2"
                                      StrokeLineCap="Round"
                                      Data="M6 6 L18 18 M18 6 L6 18"/>
                            </Viewbox>
                        </Button>
                    </Grid>

                    <StackPanel Grid.Row="1" Spacing="10">
                        <Button Classes="contact-button"
                                Command="{Binding OpenLinkedInCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Width="20"
                                        Height="20"
                                        CornerRadius="3"
                                        Background="#0A66C2">
                                    <TextBlock Text="in"
                                               Foreground="#FFFFFF"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="LinkedIn"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Classes="contact-button"
                                Command="{Binding OpenGitHubCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Viewbox Width="20" Height="20">
                                    <Path Width="24"
                                          Height="24"
                                          Fill="#24292F"
                                          Data="M12 2C6.48 2 2 6.58 2 12.26c0 4.49 2.87 8.3 6.84 9.64.5.1.68-.22.68-.49v-1.72c-2.78.62-3.37-1.22-3.37-1.22-.45-1.19-1.11-1.51-1.11-1.51-.91-.64.07-.63.07-.63 1 .07 1.52 1.05 1.52 1.05.9 1.58 2.36 1.12 2.94.86.09-.67.35-1.12.63-1.38-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.31.1-2.71 0 0 .84-.28 2.75 1.05A9.3 9.3 0 0 1 12 6.84c.85 0 1.71.12 2.51.34 1.9-1.33 2.74-1.05 2.74-1.05.55 1.4.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.93-2.34 4.8-4.57 5.06.36.32.68.94.68 1.9v2.85c0 .27.18.59.69.49A10.08 10.08 0 0 0 22 12.26C22 6.58 17.52 2 12 2z"/>
                                </Viewbox>
                                <TextBlock Text="GitHub"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
